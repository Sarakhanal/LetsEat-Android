<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="kr.ac.uc.letseat">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LetsEat">

        <!-- 🔑 Launcher Activity -->
        <activity android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Hotel List screen -->
        <activity android:name=".ui.HotelListActivity"
            android:exported="true" />

        <!-- Menu List screen -->
        <activity android:name=".ui.MenuListActivity"
            android:exported="true" />

        <!-- Signup screen -->
        <activity android:name=".ui.SignupActivity"
            android:exported="true" />

        <!-- Main screen -->
        <activity android:name=".ui.MainActivity"
            android:exported="true" />

        <!-- ✅ Added new activities -->
        <activity android:name=".ui.CartActivity"
            android:exported="true" />

        <activity android:name=".ui.CheckoutActivity"
            android:exported="true" />

        <activity android:name=".ui.OrderStatusActivity"
            android:exported="true" />

    </application>
</manifest>
