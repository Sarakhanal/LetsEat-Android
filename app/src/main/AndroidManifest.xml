<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="kr.ac.uc.letseat">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="Lets Eat"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LetsEat"
        android:usesCleartextTraffic="true">

        <!-- 🟢 Launcher (First screen when app opens) -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 🟣 User flow screens -->
        <activity android:name=".ui.SignupActivity" android:exported="false" />
        <activity android:name=".ui.MainActivity" android:exported="false" />
        <activity android:name=".ui.HotelListActivity" android:exported="false" />
        <activity android:name=".ui.MenuActivity" android:exported="false" />
        <activity android:name=".ui.MenuListActivity" android:exported="false" />
        <activity android:name=".ui.CartActivity" android:exported="false" />
        <activity android:name=".ui.CheckoutActivity" android:exported="false" />
        <activity android:name=".ui.OrderStatusActivity" android:exported="false" />

        <!-- 🧠 Seeder (for Firebase test data, NOT launcher) -->
        <activity
            android:name=".ui.DataSeederActivity"
            android:exported="false" />

    </application>

</manifest>
